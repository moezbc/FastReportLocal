# FastReport - Fichier Environnement d'Exemple
# Copiez ce fichier en '.env' et modifiez les valeurs ci-dessous

# ==========================================
# CONFIGURATION GÉNÉRALE DJANGO
# ==========================================
# Obligatoire. Utilisez une chaîne de caractères longue et aléatoire en production.
SECRET_KEY=votre_cle_secrete_longue_et_aleatoire

# 'True' pour le développement, 'False' en production
DEBUG=False

# Liste des hôtes autorisés (ex: "127.0.0.1,localhost,monserveur.net")
ALLOWED_HOSTS=*

# URL racine du backend (pour les liens dans les emails etc.)
BACKEND_URL=http://localhost:8000

# ==========================================
# CONFIGURATION BASE DE DONNÉES DJANGO
# ==========================================
# (La base contenant les rapports, historiques, et configurations de FastReport)
POSTGRES_DB=fastreport
POSTGRES_USER=fastreport_user
POSTGRES_PASSWORD=mot_de_passe_fort
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==========================================
# REDIS / CELERY
# ==========================================
# Configuration de Task Queue (Planificateur)
# Si vous utilisez "redis_portable" (sur Windows) ou Redis Host (sur Linux), laissez localhost.
# Si vous utilisez Docker Compose, remplacez par "redis://redis:6379/0"
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==========================================
# CORS (FRONTEND)
# ==========================================
# Où est hébergé le frontend (pour que le backend accepte les requêtes depuis ce domaine)
# Exemple: http://monsite.com,https://monsite.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# SÉCURITÉ / TOKENS
# ==========================================
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
